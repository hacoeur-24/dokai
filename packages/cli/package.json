{
  "name": "dokai-kit",
  "version": "1.1.0",
  "private": false,
  "description": "DOKAI — installable, local-first documentation product. CLI entry for init, dev, build, generate, update, bump.",
  "type": "module",
  "bin": {
    "dokai": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hacoeur-24/dokai.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "dokai-ai": "workspace:*",
    "dokai-core": "workspace:*",
    "dokai-ui": "workspace:*",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "hacoeur-24 (https://github.com/hacoeur-24)",
  "homepage": "https://github.com/hacoeur-24/dokai#readme",
  "bugs": {
    "url": "https://github.com/hacoeur-24/dokai/issues"
  },
  "keywords": [
    "documentation",
    "docs",
    "markdown",
    "local-first",
    "cli",
    "claude",
    "claude-code",
    "mermaid",
    "vite",
    "react",
    "monorepo"
  ]
}
