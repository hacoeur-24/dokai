{
  "name": "dokai-ui",
  "version": "1.1.0",
  "private": false,
  "description": "DOKAI documentation UI (React + Vite + Tailwind + ShadCN) and the Vite plugin that mounts /api middleware in dev and produces a static build.",
  "type": "module",
  "main": "./dist/plugin/index.js",
  "types": "./dist/plugin/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./app": {
      "default": "./src/main.tsx"
    },
    "./app-html": {
      "default": "./index.html"
    }
  },
  "files": [
    "dist",
    "src",
    "index.html",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!dist/**/*.tsbuildinfo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hacoeur-24/dokai.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && vite build",
    "build:plugin": "tsup --config tsup.config.ts",
    "build:app": "vite build",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.plugin.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src plugin",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "dokai-core": "workspace:*",
    "@scalar/api-reference": "^1.60.0",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "chokidar": "^4.0.3",
    "chrome-launcher": "^1.1.2",
    "puppeteer-core": "^23.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.4.1",
    "minisearch": "^7.1.1",
    "react-router-dom": "^7.1.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "tailwind-merge": "^2.6.0",
    "react-markdown": "^9.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7",
    "@milkdown/crepe": "^7.6.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5"
  },
  "license": "MIT",
  "author": "hacoeur-24 (https://github.com/hacoeur-24)",
  "homepage": "https://github.com/hacoeur-24/dokai#readme",
  "bugs": {
    "url": "https://github.com/hacoeur-24/dokai/issues"
  },
  "keywords": [
    "dokai",
    "documentation",
    "react",
    "vite",
    "tailwind",
    "ui",
    "milkdown"
  ],
  "engines": {
    "node": ">=22"
  }
}
